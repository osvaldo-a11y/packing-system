PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=packing_system

# Opcional en PaaS (Railway, Render, Heroku): si esta definida, se ignora DB_* para la conexion.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# En Postgres gestionado con SSL, no desactivar salvo que el proveedor lo indique.
# DB_SSL_DISABLED=true

# JWT (obligatorio en produccion)
JWT_SECRET=cambiar-por-secreto-largo-aleatorio
JWT_EXPIRES_IN=8h

# Usuarios de login (JSON). Sustituir por base de datos o IdP en produccion.
# Contrasenas en texto plano solo para desarrollo; usar bcrypt u OAuth2 en produccion.
AUTH_USERS_JSON=[{"username":"admin","password":"admin123","role":"admin"},{"username":"supervisor","password":"sup123","role":"supervisor"},{"username":"operator","password":"op123","role":"operator"}]
