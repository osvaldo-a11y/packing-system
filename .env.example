PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=packing_system

# TypeORM: ejecutar migraciones al iniciar (por defecto activo). Desactivar: false
RUN_MIGRATIONS_ON_STARTUP=true

# Opcional en PaaS (Railway, Render, Heroku): si esta definida, se ignora DB_* para la conexion.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# En Postgres gestionado con SSL, no desactivar salvo que el proveedor lo indique.
# DB_SSL_DISABLED=true

# Nombre de la empresa en PDFs de liquidación al productor (opcional).
# COMPANY_DISPLAY_NAME=Mi Empresa S.A.

# JWT (obligatorio en produccion)
JWT_SECRET=cambiar-por-secreto-largo-aleatorio
JWT_EXPIRES_IN=8h

# Usuarios de login (JSON en una linea).
# Produccion: usar passwordHash (bcrypt). Generar: npm run auth:hash-password -- tu_clave
# Desarrollo: puedes usar "password" en texto plano si no hay passwordHash.
# AUTH_USERS_JSON=[{"username":"admin","passwordHash":"$2b$12$...","role":"admin"}]
AUTH_USERS_JSON=[{"username":"admin","password":"admin123","role":"admin"},{"username":"supervisor","password":"sup123","role":"supervisor"},{"username":"operator","password":"op123","role":"operator"}]
