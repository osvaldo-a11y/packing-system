{
  "name": "packing-system",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:frontend": "npm install --prefix frontend && npm run build --prefix frontend",
    "build": "npm run build:frontend && node ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "node dist/main.js",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "dev:web": "npm run dev --prefix frontend",
    "dev:full": "node scripts/dev-api-and-web.mjs",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:run:prod": "node scripts/run-migrations-prod.cjs",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/AutoMigration",
    "dev:up": "docker compose up -d && npm run migration:run",
    "dev:down": "docker compose down",
    "dev:reset-db": "docker compose down -v && docker compose up -d && npm run migration:run",
    "dev:clear-data": "node scripts/clear-dev-data.cjs",
    "dev:clear-packaging": "node scripts/clear-packaging-catalog.cjs",
    "seed:validation": "node scripts/seed-validation-flow.cjs",
    "auth:hash-password": "node scripts/hash-auth-password.cjs",
    "screenshots:app": "node scripts/capture-app-screenshots.mjs",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:e2e:pg": "docker compose up -d && node scripts/wait-postgres.cjs && npm run migration:run && cross-env FLOW_E2E_PG=1 LIQUIDACION_E2E_PG=1 jest --config test/jest-e2e.json --runInBand",
    "test:liquidacion-e2e": "cross-env LIQUIDACION_E2E_PG=1 jest --config test/jest-e2e.json test/producer-settlement-liquidacion.e2e-spec.ts --runInBand"
  },
  "dependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/archiver": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.4",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.12",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "sql.js": "^1.11.0",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2"
  }
}
